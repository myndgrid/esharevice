# ============================================================
# e-Sharevice — Environment Configuration
# Copy this file to .env (root) and per-app .env.local files.
# NEVER commit .env or .env.local.
# ============================================================

# === SHARED ===
NODE_ENV=development

# === DATABASE (Postgres 16) ===
DATABASE_URL=postgresql://esharevice:esharevice@localhost:5432/esharevice  # App DB connection string

# === REDIS (rate limit / refresh tokens / idempotency / cache) ===
REDIS_URL=redis://localhost:6379

# === API (apps/api) ===
API_PORT=8080
API_PUBLIC_URL=http://localhost:8080      # Public URL clients reach the API at
WEB_ORIGIN=http://localhost:3000          # Comma-separated allowlist for CORS

# === OIDC (API verifier — Authentik today, Auth.js after PR 1b) ===
# The API never signs tokens, only verifies. During the 7-day Authentik →
# Auth.js migration window the verifier accepts BOTH issuers — `iss` claim
# selects which JWKS to use. After the flip, set these to the Auth.js values:
#   OIDC_ISSUER     → https://your-domain.com
#   OIDC_AUDIENCE   → esharevice-api
#   OIDC_JWKS_URL   → https://your-domain.com/.well-known/jwks.json
OIDC_ISSUER=https://auth.your-domain.com/application/o/e-sharevice-web/
OIDC_AUDIENCE=e-sharevice-web              # client_id / audience this API trusts
OIDC_JWKS_URL=https://auth.your-domain.com/application/o/e-sharevice-web/jwks/

# === WEB (apps/web) ===
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080  # Browser-visible API base
OIDC_CLIENT_ID=e-sharevice-web
OIDC_CLIENT_SECRET=replace-me              # From Authentik Application → Provider
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
SESSION_COOKIE_SECRET=replace-me-32-bytes  # 32-byte hex for cookie signing

# === AUTH.JS (PR 1b — consumed when Auth.js wires in) ===
# Scaffolding only; not yet read by any code. See apps/web/.env.example for
# how each value is generated and where it's used.
AUTH_SECRET=
AUTH_JWT_PRIVATE_KEY=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_APPLE_ID=
AUTH_APPLE_TEAM_ID=
AUTH_APPLE_KEY_ID=
AUTH_APPLE_PRIVATE_KEY=
AUTH_RESEND_FROM=auth@your-domain.com

# === OBJECT STORAGE (Cloudflare R2 — S3-compatible) ===
# Create the S3-compatible API token in the Cloudflare dashboard (Dashboard → R2
# → Manage R2 API tokens → Create), permissions = Object Read & Write, scoped
# to a single bucket. Save the keys once — they're shown only on creation.
R2_ACCOUNT_ID=                                # Cloudflare account id
R2_ACCESS_KEY_ID=                             # from the R2 API token
R2_SECRET_ACCESS_KEY=                         # from the R2 API token
R2_BUCKET=esharevice-images                   # bucket name (created via API at provision time)
CDN_BASE_URL=https://cdn.your-domain.com      # custom domain bound to the bucket (or pub-*.r2.dev)

# === EMAIL (Resend) ===
# Application-level transactional emails (lands week 7 with notification feature).
# Authentik's password-reset / verification emails are wired via SMTP from infra/.env, NOT here.
RESEND_API_KEY=                            # send-only key from https://resend.com/api-keys
EMAIL_FROM=noreply@your-domain.com         # must be on a domain verified in resend.com/domains

# === OBSERVABILITY ===
SENTRY_DSN_WEB=                            # from Sentry project esharevice-web
SENTRY_DSN_API=                            # from Sentry project esharevice-api
