# === SECRETS & CREDENTIALS ===
# Ignore EVERY dotenv variant by default, then explicitly allow .env.example files.
.env
.env.*
**/.env
**/.env.*
*.creds
*.secret
*.secrets
!.env.example
!**/.env.example

# Keys and certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# Token files
tokens/
*.token.json

# === RUNTIME / BUILD ===
node_modules/
.pnpm-store/
.pnpm-debug.log*
dist/
build/
.next/
.turbo/
.cache/
.vite/
*.tsbuildinfo

# next-pwa generates these on every `next build`. Treat them as build
# artifacts, not source — they're regenerated deterministically by CI.
apps/web/public/sw.js
apps/web/public/sw.js.map
apps/web/public/workbox-*.js
apps/web/public/workbox-*.js.map
apps/web/public/fallback-*.js

# === LOGS & OUTPUT ===
logs/
*.log
output/
tmp/
coverage/

# === OS & IDE ===
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.sw?
*.swp

# === LOCAL-ONLY TOOL CONFIG ===
# Claude Code's per-machine settings can contain plaintext credentials in its
# Bash permission allow rules (E2E_PASSWORD=…). Never commit this directory.
.claude/
# gstack writes security reports + checkpoints here. Reports contain file
# paths + descriptions of attack surface — keep them out of git history.
.gstack/

# === DATABASE / GENERATED ===
*.sqlite
*.sqlite-journal
drizzle/*.snapshot.json
drizzle/migrations.json

# === MISC ===
*.tmp
*.temp
*.zip
*.tar.gz

# === REFERENCE-ONLY DIRECTORY ===
# Repo/ contains the legacy JS apps. It is kept for reference but is NOT part of the monorepo.
# Comment the next line out if you ever want to vendor these into the workspace.
Repo/
YCombinator/