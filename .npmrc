# Use hoisted (npm-style flat) linking so TypeScript's standard @types/*
# discovery works without per-package typeRoots gymnastics. pnpm's default
# isolated linking puts transitive @types in `.pnpm/<pkg>/node_modules/@types/`
# which TS Bundler-mode resolution can't follow through `/// <reference types>`
# directives (e.g. @types/express references express-serve-static-core).
node-linker=hoisted
