# apps/api reads these. The root .env.example documents the full set.
NODE_ENV=development
API_PORT=8080
API_PUBLIC_URL=http://localhost:8080
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://esharevice:esharevice@localhost:5432/esharevice
REDIS_URL=redis://localhost:6379

# === OIDC verifier (Authentik today, Auth.js after PR 1b) ===
# The API only verifies JWTs — never signs. During the 7-day migration window
# the verifier accepts BOTH issuers (Authentik + Auth.js) via `iss`-routed
# JWKS resolution. After the flip, set these to the Auth.js endpoints:
#   OIDC_ISSUER   → https://your-domain.com
#   OIDC_AUDIENCE → esharevice-api
#   OIDC_JWKS_URL → https://your-domain.com/.well-known/jwks.json
OIDC_ISSUER=https://auth.your-domain.com/application/o/e-sharevice-web/
OIDC_AUDIENCE=e-sharevice-web
OIDC_JWKS_URL=https://auth.your-domain.com/application/o/e-sharevice-web/jwks/

# === Auth.js second-issuer (PR 1b migration window) ===
# The API trusts tokens from BOTH Authentik (OIDC_*) and Auth.js (AUTHJS_*)
# while the migration is in flight. iss-routed JWKS resolution picks the
# right verifier. Leave AUTHJS_ISSUER blank to disable the second issuer.
# In dev, AUTHJS_ISSUER is the web origin (http://localhost:3000); JWKS is
# derived live from AUTH_JWT_PRIVATE_KEY by apps/web/.well-known/jwks.json.
AUTHJS_ISSUER=http://localhost:3000
AUTHJS_JWKS_URL=http://localhost:3000/.well-known/jwks.json
AUTHJS_AUDIENCE=esharevice-api

# === Feature flags ===
# FEATURE_LISTING_TYPES — gates the new /v1/categories endpoint (404 when off).
# Additive response fields on /v1/exchange-items ship regardless; old clients
# ignore unknown keys, so this flag's only job is hiding the new endpoint
# until UI is ready. Default off. Accepts: 1 / true / yes / on (case-insensitive).
FEATURE_LISTING_TYPES=false

# ─── Revenue path flags — flip TOGETHER when ready ───
# The marketplace booking + payment loop needs BOTH flags. Flipping only one
# leaves the system half-wired:
#   FEATURE_BOOKINGS=true  + FEATURE_STRIPE=false → bookings work, no payment leg
#   FEATURE_BOOKINGS=false + FEATURE_STRIPE=true  → /v1/payouts/* works but
#     POST /v1/items/:id/bookings 404s (you can onboard providers but they
#     can't accept any bookings yet)
# Operator runbook (PR 11): flip both `true` after PR 9's booking flow UI
# ships AND first 10 providers have completed Stripe onboarding.

# FEATURE_BOOKINGS — gates /v1/bookings endpoints + activate/complete cron jobs
# (no-op when off). Schema (migration 0008) lives in prod from day one.
FEATURE_BOOKINGS=false

# FEATURE_STRIPE — gates /v1/payouts/* + /v1/webhooks/stripe endpoints (404
# when off) AND the Stripe payment leg inside the booking lifecycle. When
# FEATURE_BOOKINGS=true + FEATURE_STRIPE=false, bookings are created with
# stripe_payment_intent_id=null (no client_secret on POST response).
FEATURE_STRIPE=false

# === Stripe Connect (PR 4) ===
# Test mode: keys start with sk_test_* / whsec_*. Production: sk_live_*.
# When STRIPE_SECRET_KEY is absent, every /v1/payouts/* endpoint returns
# 503 (mirrors the R2 env-gate pattern).
# Webhook secret: from `stripe listen` for local dev, or Developers →
# Webhooks → endpoint signing secret for production.
STRIPE_SECRET_KEY=                       # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=                   # whsec_...
STRIPE_ACCOUNT_COUNTRY=CA                # country for newly-created Connect accounts
