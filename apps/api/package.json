{
  "name": "@esharevice/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@esharevice/db": "workspace:*",
    "@esharevice/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/swagger-ui": "^0.5.0",
    "@hono/zod-openapi": "^0.18.4",
    "@sentry/node": "^10.53.1",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "hono-rate-limiter": "^0.4.2",
    "ioredis": "^5.10.1",
    "jose": "^5.9.6",
    "pino": "^9.5.0",
    "resend": "^6.12.3",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
