# apps/web reads these. The root .env.example documents the full set.
NODE_ENV=development
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# === OIDC (Authentik — current; Auth.js takes over in PR 1b) ===
# Both stacks read the same vars; only the values change. During the 7-day
# migration overlap, OIDC_ISSUER + OIDC_JWKS_URL flip to the Auth.js endpoints
# while OIDC_CLIENT_ID/SECRET stay only for the legacy oauth4webapi flow.
OIDC_ISSUER=https://auth.your-domain.com/application/o/e-sharevice-web/
OIDC_CLIENT_ID=e-sharevice-web
OIDC_CLIENT_SECRET=replace-me
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
SESSION_COOKIE_SECRET=replace-me-32-bytes

# === AUTH.JS (PR 1b — wires Google + Apple + magic-link + credentials) ===
# Not consumed yet; the next sub-PR will read them. Listed here so onboarding
# and infra/.env stay in sync.
#
# AUTH_SECRET — 32-byte random base64. `openssl rand -base64 32`.
# Used by Auth.js to encrypt the JWE session cookie + sign callback nonces.
AUTH_SECRET=

# AUTH_JWT_PRIVATE_KEY — RS256 PKCS#8 private key, base64-encoded so the
# value fits on one line (dotenv parsers, Docker Compose env: blocks, and
# Coolify don't deal cleanly with multi-line PEM). The consumer code decodes
# with `Buffer.from(env, 'base64').toString('utf8')` before passing to jose.
#
# Generate ONCE per environment, preserve across deploys (rotating it logs
# every active session out):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 | base64
#
# Keep in your secrets store (Conductor / 1Password / Bitwarden); never commit.
# The Auth.js session callback signs an OIDC-shaped JWT with this; the Hono
# API verifies via the JWKS at /.well-known/jwks.json (derived at runtime
# from this key — there's no second env var for the public counterpart).
AUTH_JWT_PRIVATE_KEY=

# AUTH_GOOGLE_ID / SECRET — Google OAuth 2.0 client.
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth client
# Authorized redirect URI:  http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# AUTH_APPLE_* — Apple Sign In. Requires Apple Developer Program enrollment
# (CAD $129/yr). Optional at v1 launch; ship Google + magic-link first.
# Services ID format: com.esharevice.web.signin
# Private key: contents of the .p8 file from developer.apple.com/account/resources/authkeys.
AUTH_APPLE_ID=
AUTH_APPLE_TEAM_ID=
AUTH_APPLE_KEY_ID=
AUTH_APPLE_PRIVATE_KEY=

# Resend reused for the magic-link transport (existing infra/.env credentials).
RESEND_API_KEY=
AUTH_RESEND_FROM=auth@your-domain.com
