# ============================================================
# infra/.env — production stack secrets (NEVER commit)
# Copy this file to infra/.env on the VPS and fill in real values.
# ============================================================

# === DOMAIN / TLS ===
DOMAIN=your-domain.com
LETSENCRYPT_EMAIL=ops@your-domain.com

# === IMAGE REGISTRY ===
GHCR_OWNER=your-github-org-or-user           # ghcr.io/<owner>/esharevice-{web,api}
WEB_IMAGE_TAG=latest
API_IMAGE_TAG=latest

# === APP DATABASE ===
POSTGRES_DB=esharevice
POSTGRES_USER=esharevice
POSTGRES_PASSWORD=replace-with-32+-random-chars

# === AUTHENTIK DATABASE (dedicated) ===
AUTHENTIK_POSTGRES_PASSWORD=replace-with-32+-random-chars
AUTHENTIK_SECRET_KEY=replace-with-50+-random-chars   # pwgen -s 50 1

# === AUTHENTIK EMAIL (Resend SMTP) ===
# IMPORTANT: domain in AUTHENTIK_EMAIL_FROM must be verified at https://resend.com/domains
# (DKIM + SPF DNS records). Until then, sends will 403.
AUTHENTIK_EMAIL_HOST=smtp.resend.com
AUTHENTIK_EMAIL_PORT=587
AUTHENTIK_EMAIL_USERNAME=resend
AUTHENTIK_EMAIL_PASSWORD=                  # send-only Resend API key (https://resend.com/api-keys)
AUTHENTIK_EMAIL_FROM=noreply@your-domain.com

# === WEB ⇄ AUTHENTIK ===
# Get the client secret from Authentik admin UI after blueprint applies:
#   Applications → Providers → e-sharevice-web → Edit → Client Secret
OIDC_CLIENT_SECRET=

# === COOKIE SIGNING (web) ===
# 32-byte hex: openssl rand -hex 32
SESSION_COOKIE_SECRET=

# === UPTIME KUMA BASIC AUTH (Caddy edge) ===
# docker run --rm caddy:2-alpine caddy hash-password -plaintext 'your-pass'
UPTIME_BASIC_AUTH_HASH=

# === OBSERVABILITY ===
SENTRY_DSN_WEB=
SENTRY_DSN_API=

# === CLOUDFLARE R2 (image uploads) ===
# Until these five are filled in, POST /v1/exchange-items/:id/image returns 503.
# Create the S3-compatible API token in the Cloudflare dashboard:
#   R2 → Manage R2 API tokens → Create API token
#     Token name:  esharevice-api-uploads
#     Permissions: Object Read & Write
#     Bucket:      esharevice-images   (scope to a single bucket)
#   Save the Access Key ID + Secret Access Key (shown ONCE).
# Bucket itself + cdn.esharevice.com custom domain are created separately
# (bucket via API at provision time; custom domain via the dashboard
#   R2 → esharevice-images → Settings → Custom Domains → cdn.esharevice.com).
R2_ACCOUNT_ID=                                       # Cloudflare account id (Dashboard sidebar → R2)
R2_ACCESS_KEY_ID=                                    # from R2 API token creation
R2_SECRET_ACCESS_KEY=                                # from R2 API token creation
R2_BUCKET=esharevice-images                          # bucket name
CDN_BASE_URL=https://cdn.your-domain.com             # custom domain bound to the bucket

# === TRANSACTIONAL EMAIL (Resend) ===
# Optional. Until both are set, the API's owner-notification-on-reserve
# helper is a silent no-op. The same Resend account already powers
# Authentik's password-reset / verification emails (AUTHENTIK_EMAIL_*).
#
# IMPORTANT: the sender domain must be verified at https://resend.com/domains
# (DKIM + SPF DNS records). Until then, sends return 403 validation_error
# (captured in Sentry + logged, never fails the reserve).
RESEND_API_KEY=                                       # send-only key from resend.com/api-keys
EMAIL_FROM=e-Sharevice <noreply@your-domain.com>      # FROM address on a verified domain
# Optional override; defaults to https://${DOMAIN} via compose.
# WEB_PUBLIC_URL=https://your-domain.com

# === SOCIAL OAUTH (Google + GitHub via Authentik) ===
# Optional. Until these are set + the blueprint template is dropped in as
# `infra/authentik/blueprints/social.yaml`, Authentik shows only the
# username/password login flow (Sign in via Authentik is unaffected).
# Full setup: docs/features/2026-05-16_social-oauth.md.
#
# Google: https://console.cloud.google.com → OAuth consent screen + Credentials
# → OAuth 2.0 Client ID (Web application). Authorized redirect:
#   https://auth.your-domain.com/source/oauth/callback/google/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
#
# GitHub: https://github.com/settings/developers → OAuth Apps → New.
# Authorization callback URL:
#   https://auth.your-domain.com/source/oauth/callback/github/
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
