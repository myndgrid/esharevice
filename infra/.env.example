# ============================================================
# infra/.env — production stack secrets (NEVER commit)
# Copy this file to infra/.env on the VPS and fill in real values.
# Post Phase 3 — Authentik is gone; Auth.js runs inside apps/web.
# ============================================================

# === DOMAIN / TLS ===
DOMAIN=your-domain.com
LETSENCRYPT_EMAIL=ops@your-domain.com

# === IMAGE REGISTRY ===
GHCR_OWNER=your-github-org-or-user           # ghcr.io/<owner>/esharevice-{web,api}
WEB_IMAGE_TAG=latest
API_IMAGE_TAG=latest

# === APP DATABASE ===
POSTGRES_DB=esharevice
POSTGRES_USER=esharevice
POSTGRES_PASSWORD=replace-with-32+-random-chars

# === AUTH.JS (consumed by apps/web; full notes in apps/web/.env.example) ===
AUTH_SECRET=                                          # `openssl rand -base64 32`
AUTH_JWT_PRIVATE_KEY=                                  # `openssl genpkey ... | base64`
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_RESEND_FROM=auth@your-domain.com

# === UPTIME KUMA BASIC AUTH (Caddy edge) ===
# docker run --rm caddy:2-alpine caddy hash-password -plaintext 'your-pass'
UPTIME_BASIC_AUTH_HASH=

# === OBSERVABILITY ===
SENTRY_DSN_WEB=
SENTRY_DSN_API=

# === CLOUDFLARE R2 (image uploads) ===
# Until these five are filled in, POST /v1/exchange-items/:id/image returns 503.
# R2 → Manage R2 API tokens → Create. Permissions = Object Read & Write,
# scoped to a single bucket. Save the keys once — shown only on creation.
R2_ACCOUNT_ID=                                       # Cloudflare account id (Dashboard sidebar → R2)
R2_ACCESS_KEY_ID=                                    # from R2 API token creation
R2_SECRET_ACCESS_KEY=                                # from R2 API token creation
R2_BUCKET=esharevice-images                          # bucket name
CDN_BASE_URL=https://cdn.your-domain.com             # custom domain bound to the bucket

# === TRANSACTIONAL EMAIL (Resend) ===
# Both this app's transactional email and Auth.js magic-link delivery use
# the same Resend API key. Sender domain must be verified at
# https://resend.com/domains (DKIM + SPF DNS records).
RESEND_API_KEY=                                       # send-only key from resend.com/api-keys
EMAIL_FROM=e-Sharevice <noreply@your-domain.com>      # FROM address on a verified domain
# Optional override; defaults to https://${DOMAIN} via compose.
# WEB_PUBLIC_URL=https://your-domain.com

# === STRIPE CONNECT (PR 4) ===
# Test mode: sk_test_* / whsec_*. Production: sk_live_*.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ACCOUNT_COUNTRY=CA

# === FEATURE FLAGS (API) ===
# Gates feature surface area on the Hono API. Off by default so a half-
# migrated env can't expose half-baked endpoints. Flip on once the schema
# migrations + downstream wiring have shipped.
FEATURE_LISTING_TYPES=true   # /v1/categories + listing_type / category_slug on /v1/exchange-items
FEATURE_BOOKINGS=true        # /v1/bookings + /v1/items/{id}/bookings
FEATURE_STRIPE=true          # /v1/payouts/* + /v1/webhooks/stripe
